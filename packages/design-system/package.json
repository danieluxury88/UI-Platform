{
  "name": "@ui-platform/design-system",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.cjs.js",
  "module": "dist/index.js",
  "types": "dist/types/components.d.ts",
  "collection": "dist/collection/collection-manifest.json",
  "collection:main": "dist/collection/index.js",
  "style": "styles.css",
  "exports": {
    ".": {
      "types": "./dist/types/components.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs.js",
      "default": "./dist/index.js"
    },
    "./loader": {
      "types": "./dist/loader/index.d.ts",
      "import": "./dist/loader/index.js",
      "require": "./dist/loader/index.cjs.js",
      "default": "./dist/loader/index.js"
    },
    "./styles.css": "./styles.css",
    "./src/styles.css": "./src/styles.css"
  },
  "files": [
    "dist/",
    "styles.css",
    "src/styles.css"
  ],
  "dependencies": {
    "@ui-platform/tokens": "workspace:*"
  },
  "devDependencies": {
    "@stencil/core": "^4.12.0",
    "@types/jest": "^29.5.14",
    "jest": "^29.7.0",
    "jest-cli": "^29.7.0",
    "typescript": "^5.4.0"
  },
  "scripts": {
    "build": "stencil build",
    "dev": "stencil build --watch --serve",
    "generate": "stencil generate",
    "lint": "node ../../scripts/validate-design-system-structure.mjs",
    "test": "stencil test --spec",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  }
}
